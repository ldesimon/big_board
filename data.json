      "id": "1213641001883177",
      "name": "Replacing Tableau with Data Portal",
      "stage": "Initial Brainstorm",
      "creator": "Cristina",
      "shareLink": null,
      "screenshot": null,
      "notes": {
        "purpose": "Replace all scattered Tableau URLs and Google Sheets with one site for data access and visualizations built in code using best-fit tools (charting libraries, Streamlit, JS). Add self-service tools from the Semantic Layer plus LLM 'talk to the data' for every dataset.",
        "audience": "Everyone",
        "timeline": "Rolled out gradually as semantic layer is built — 2026–2027",
        "nextSteps": [
          "Use Claude to supercharge semantic layer development: suggest star schema design, create fact/dim tables, write yaml metadata files",
          "Replace Tableau with self-hosted visualization site reading from semantic layer directly",
          "Create access tiers: internal users and public views for outside stakeholders and the Board"
        ],
        "productionAudit": [
          "Semantic Layer product selection happening in < 1 week",
          "Additional specs & designing needed",
          "Need Auth + Permissions (including Job Groupings for global access rules)",
          "Decide on hosting platform"
        ]
      }
